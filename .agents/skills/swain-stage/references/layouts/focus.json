{
  "name": "focus",
  "description": "Agent with MOTD top-right and file browser bottom-right",
  "panes": [
    {
      "position": "main",
      "type": "agent",
      "comment": "Main pane — the agent session (already running)"
    },
    {
      "position": "right",
      "size": "35%",
      "type": "browser",
      "command": "{fileBrowser} {repoRoot}"
    },
    {
      "position": "top",
      "size": "12",
      "type": "motd",
      "command": "uv run {scriptDir}/swain-motd.py"
    }
  ]
}
