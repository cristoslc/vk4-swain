{
  "name": "browse",
  "description": "File browser in side pane, MOTD at bottom",
  "panes": [
    {
      "position": "main",
      "type": "agent",
      "comment": "Main pane — the agent session (already running)"
    },
    {
      "position": "right",
      "size": "40%",
      "type": "browser",
      "command": "{fileBrowser} {repoRoot}"
    },
    {
      "position": "bottom",
      "size": "12",
      "type": "motd",
      "command": "bash {scriptDir}/swain-motd.sh"
    }
  ]
}
